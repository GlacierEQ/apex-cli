{
  "name": "apex-cli",
  "version": "2.0.0",
  "description": "APEX CLI — Unified legal-ops terminal with Gemini AI | Case 1FDV-23-0001009",
  "main": "apex.js",
  "bin": {
    "apex": "./apex.js",
    "apex-gemini": "./src/commands/gemini-chat.ts"
  },
  "scripts": {
    "gemini":       "ts-node src/commands/gemini-chat.ts",
    "gemini:pro":   "ts-node src/commands/gemini-chat.ts --model pro",
    "gemini:daily": "ts-node src/commands/gemini-daily.ts",
    "analyze":      "ts-node src/commands/gemini-analyze.ts",
    "research":     "ts-node src/commands/gemini-analyze.ts --task research --model pro",
    "draft":        "ts-node src/commands/gemini-analyze.ts --task draft --model pro",
    "summarize":    "ts-node src/commands/gemini-analyze.ts --task summarize",
    "health":       "ts-node src/commands/apex-health.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "readline": "^1.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.9"
  }
}
